rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ─── Users ─────────────────────────────────────────────────────────────────
    // Cada usuário lê/escreve apenas seu próprio perfil.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Public Profiles ───────────────────────────────────────────────────────
    // Espelho público do perfil usado na página /@username.
    match /publicProfiles/{uid} {
      allow read:   if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ─── Usernames (mapeamento username → uid, público para checagem) ──────────
    // Leitura pública para verificar disponibilidade; escrita apenas no registro.
    match /usernames/{username} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ─── Links (subcoleção users/{uid}/links) ─────────────────────────────────
    // Leitura pública (p.html renderiza sem auth); escrita só do dono.
    match /users/{uid}/links/{linkId} {
      allow read:   if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ─── Widgets (subcoleção users/{uid}/widgets) ────────────────────────────
    // Leitura pública para a página /@username; escrita só do dono.
    match /users/{uid}/widgets/{widgetId} {
      allow read:   if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
    }

    // ─── Clicks (subcoleção users/{uid}/links/{linkId}/clicks) ────────────────
    // Qualquer pessoa pode registrar um clique (write público).
    // Leitura só do dono.
    match /users/{uid}/links/{linkId}/clicks/{clickId} {
      allow read:   if isOwner(uid);
      allow create: if true;
      allow update, delete: if false;
    }

    // ─── Tudo mais: negar por padrão ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
