[
  {
    "type": "link-button",
    "name": "Link Button",
    "category": "essentials",
    "description": "Link clássico com ícone e título",
    "icon": "🔗",
    "iconBg": "#F0EDE8",
    "iconColor": "#4A5068",
    "sizes": ["2x1"],
    "defaultSize": "2x1",
    "tier": "free",
    "version": "1.0.0",
    "status": "active",
    "configSchema": [
      {"key": "title",     "label": "Título",         "type": "text",    "required": true,  "default": "Meu Link",  "placeholder": "Ex: Meu produto"},
      {"key": "subtitle",  "label": "Subtítulo",       "type": "text",    "required": false, "default": ""},
      {"key": "url",       "label": "URL",             "type": "url",     "required": true,  "default": "",          "placeholder": "https://"},
      {"key": "iconEmoji", "label": "Ícone (emoji)",   "type": "text",    "required": false, "default": "🔗"}
    ],
    "renderTemplate": "<a href='{{url}}' target='_blank' rel='noopener' class='g-wgt g-wgt--link'><span class='g-wgt--link__icon'>{{iconEmoji}}</span><div class='g-wgt--link__body'><strong>{{title}}</strong><small>{{subtitle}}</small></div><span class='g-wgt--link__arrow'>›</span></a>",
    "renderCSS": ".g-wgt--link{display:flex;align-items:center;gap:12px;padding:14px 20px;background:var(--bg-surface,#fff);border:1px solid rgba(26,31,54,.1);border-radius:12px;transition:all 200ms ease;cursor:pointer;text-decoration:none;color:#1A1F36}.g-wgt--link:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,31,54,.1)}.g-wgt--link__icon{width:40px;height:40px;border-radius:8px;background:rgba(26,31,54,.06);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}.g-wgt--link__body{flex:1;min-width:0}.g-wgt--link__body strong{display:block;font-weight:600;font-size:.9375rem}.g-wgt--link__body small{color:rgba(26,31,54,.5);font-size:.75rem}.g-wgt--link__arrow{color:rgba(26,31,54,.3);font-size:20px}",
    "stats": {"installs": 0, "clicks": 0}
  },
  {
    "type": "whatsapp-cta",
    "name": "WhatsApp CTA",
    "category": "whatsapp",
    "description": "Botão verde com mensagem pronta",
    "icon": "💬",
    "iconBg": "#E8F8EE",
    "iconColor": "#25D366",
    "sizes": ["1x1", "2x1"],
    "defaultSize": "2x1",
    "tier": "free",
    "version": "1.0.0",
    "status": "active",
    "configSchema": [
      {"key": "phone",      "label": "Número WhatsApp",      "type": "text",     "required": true,  "placeholder": "+5511999999999", "default": ""},
      {"key": "message",    "label": "Mensagem Padrão",       "type": "textarea", "required": true,  "default": "Olá! Gostaria de saber mais sobre o getmi."},
      {"key": "buttonText", "label": "Texto do Botão",        "type": "text",     "required": false, "default": "Fale Conosco"},
      {"key": "showOnline", "label": "Mostrar Status Online", "type": "toggle",   "default": true}
    ],
    "renderTemplate": "<a href='https://wa.me/{{phone}}?text={{message}}' target='_blank' rel='noopener' class='g-wgt g-wgt--wa'><svg class='g-wgt--wa__svg' viewBox='0 0 24 24' fill='currentColor' width='28' height='28'><path d='M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.628 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'/></svg><div class='g-wgt--wa__body'><strong>{{buttonText}}</strong><span class='g-wgt--wa__status' data-show='{{showOnline}}'>● ONLINE AGORA</span></div></a>",
    "renderCSS": ".g-wgt--wa{display:flex;align-items:center;gap:16px;padding:16px 24px;background:#25D366;border-radius:999px;color:#fff;text-decoration:none;transition:all 200ms ease;cursor:pointer}.g-wgt--wa:hover{background:#20BD5A;transform:translateY(-1px);box-shadow:0 8px 24px rgba(37,211,102,.3);color:#fff}.g-wgt--wa__svg{flex-shrink:0}.g-wgt--wa__body{flex:1}.g-wgt--wa__body strong{display:block;font-weight:600;font-size:.9375rem}.g-wgt--wa__status{font-size:10px;text-transform:uppercase;letter-spacing:.06em;opacity:.85}.g-wgt--wa__status[data-show='false']{display:none}",
    "stats": {"installs": 0, "clicks": 0}
  },
  {
    "type": "spotify-player",
    "name": "Spotify Player",
    "category": "media",
    "description": "Player de música com embed oficial",
    "icon": "🎵",
    "iconBg": "#F0EDE8",
    "iconColor": "#1A1F36",
    "sizes": ["2x1", "2x2"],
    "defaultSize": "2x1",
    "tier": "free",
    "version": "1.0.0",
    "status": "active",
    "configSchema": [
      {"key": "spotifyUrl", "label": "URL do Spotify", "type": "url",    "required": true,  "placeholder": "https://open.spotify.com/track/...", "default": ""},
      {"key": "compact",    "label": "Modo Compacto",  "type": "toggle", "required": false, "default": true}
    ],
    "renderTemplate": "<div class='g-wgt g-wgt--spotify'><iframe src='https://open.spotify.com/embed/track/4cluDES4hQEUhmXj6TXkSo?theme=0' width='100%' height='{{compact}}' frameBorder='0' allow='autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture' loading='lazy' style='border-radius:12px'></iframe></div>",
    "renderCSS": ".g-wgt--spotify{border-radius:12px;overflow:hidden}",
    "apiConfig": {"service": "spotify", "endpointPattern": "https://open.spotify.com/embed/track/{{trackId}}"},
    "stats": {"installs": 0, "clicks": 0}
  },
  {
    "type": "youtube-video",
    "name": "YouTube Video",
    "category": "media",
    "description": "Vídeo embed responsivo",
    "icon": "▶️",
    "iconBg": "#F0EDE8",
    "iconColor": "#1A1F36",
    "sizes": ["2x2"],
    "defaultSize": "2x2",
    "tier": "free",
    "version": "1.0.0",
    "status": "active",
    "configSchema": [
      {"key": "youtubeUrl", "label": "URL do YouTube", "type": "url", "required": true, "placeholder": "https://youtube.com/watch?v=...", "default": ""}
    ],
    "renderTemplate": "<div class='g-wgt g-wgt--youtube'><div class='g-wgt--youtube__wrap'><iframe src='https://www.youtube.com/embed/dQw4w9WgXcQ' width='100%' height='100%' frameBorder='0' allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture' allowfullscreen loading='lazy'></iframe></div></div>",
    "renderCSS": ".g-wgt--youtube{border-radius:12px;overflow:hidden}.g-wgt--youtube__wrap{position:relative;padding-bottom:56.25%;height:0}.g-wgt--youtube__wrap iframe{position:absolute;top:0;left:0;width:100%;height:100%}",
    "stats": {"installs": 0, "clicks": 0}
  },
  {
    "type": "heading",
    "name": "Heading",
    "category": "essentials",
    "description": "Texto grande para separar seções",
    "icon": "📝",
    "iconBg": "#F0EDE8",
    "iconColor": "#4A5068",
    "sizes": ["2x1", "4x1"],
    "defaultSize": "2x1",
    "tier": "free",
    "version": "1.0.0",
    "status": "active",
    "configSchema": [
      {"key": "text",  "label": "Texto",         "type": "text",   "required": true,  "default": "Minha Seção", "placeholder": "Título da seção"},
      {"key": "align", "label": "Alinhamento",   "type": "select", "required": false, "options": ["left","center","right"], "default": "left"}
    ],
    "renderTemplate": "<div class='g-wgt g-wgt--heading' style='text-align:{{align}}'><h3>{{text}}</h3></div>",
    "renderCSS": ".g-wgt--heading{padding:8px 0}.g-wgt--heading h3{font-weight:700;font-size:1.25rem;color:#1A1F36;margin:0}",
    "stats": {"installs": 0, "clicks": 0}
  },
  {
    "type": "image",
    "name": "Image",
    "category": "essentials",
    "description": "Foto com cantos arredondados",
    "icon": "🖼️",
    "iconBg": "#F0EDE8",
    "iconColor": "#4A5068",
    "sizes": ["1x1", "2x2"],
    "defaultSize": "2x2",
    "tier": "free",
    "version": "1.0.0",
    "status": "active",
    "configSchema": [
      {"key": "imageUrl", "label": "URL da Imagem",             "type": "url",  "required": true,  "default": "", "placeholder": "https://..."},
      {"key": "altText",  "label": "Texto alternativo",          "type": "text", "required": false, "default": ""},
      {"key": "linkUrl",  "label": "Link ao clicar (opcional)", "type": "url",  "required": false, "default": ""}
    ],
    "renderTemplate": "<div class='g-wgt g-wgt--image'><img src='{{imageUrl}}' alt='{{altText}}' loading='lazy'></div>",
    "renderCSS": ".g-wgt--image{border-radius:12px;overflow:hidden}.g-wgt--image img{width:100%;height:100%;object-fit:cover;display:block}",
    "stats": {"installs": 0, "clicks": 0}
  },
  {
    "type": "pix-qr",
    "name": "Pix QR Code",
    "category": "whatsapp",
    "description": "QR Code Pix para receber pagamentos",
    "icon": "💰",
    "iconBg": "#E8F8EE",
    "iconColor": "#25D366",
    "sizes": ["2x2"],
    "defaultSize": "2x2",
    "tier": "free",
    "version": "1.0.0",
    "status": "active",
    "configSchema": [
      {"key": "pixKey",       "label": "Chave Pix",        "type": "text",   "required": true,  "placeholder": "CPF, email, telefone ou chave aleatória", "default": ""},
      {"key": "recipientName","label": "Nome do Recebedor", "type": "text",   "required": true,  "default": ""},
      {"key": "amount",       "label": "Valor R$ (0 = livre)", "type": "number", "required": false, "default": 0},
      {"key": "description",  "label": "Descrição",         "type": "text",   "required": false, "default": "Apoie meu trabalho"}
    ],
    "renderTemplate": "<div class='g-wgt g-wgt--pix'><div class='g-wgt--pix__qr' data-pix-key='{{pixKey}}' data-pix-name='{{recipientName}}' data-pix-amount='{{amount}}'><svg viewBox='0 0 100 100' width='120' height='120' xmlns='http://www.w3.org/2000/svg'><rect width='100' height='100' fill='white'/><text x='50' y='55' text-anchor='middle' font-size='10' fill='#aaa'>QR Code</text><text x='50' y='70' text-anchor='middle' font-size='8' fill='#aaa'>gerado no cliente</text></svg></div><p class='g-wgt--pix__desc'>{{description}}</p><small class='g-wgt--pix__key'>{{pixKey}}</small></div>",
    "renderCSS": ".g-wgt--pix{text-align:center;padding:24px;background:#fff;border:1px solid rgba(26,31,54,.1);border-radius:12px}.g-wgt--pix__qr{margin:0 auto 12px;display:flex;justify-content:center}.g-wgt--pix__desc{font-weight:600;font-size:.9375rem;margin:0 0 4px;color:#1A1F36}.g-wgt--pix__key{color:rgba(26,31,54,.4);font-size:.6875rem}",
    "stats": {"installs": 0, "clicks": 0}
  }
]
